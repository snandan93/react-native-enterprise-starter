# Reference values for local tooling and CI. The mobile app's public runtime
# profiles live in src/app/config/env.ts so users can switch without rebuilding.
APP_ENV=development
APP_NAME=Enterprise Starter Dev
API_BASE_URL=https://dev-api.example.com/v1
API_TIMEOUT_MS=15000
LOG_LEVEL=debug
USE_MOCK_API=true

# Never put private API keys, signing credentials, or service-account secrets in
# a React Native bundle. Keep those on your backend or in CI secret storage.
